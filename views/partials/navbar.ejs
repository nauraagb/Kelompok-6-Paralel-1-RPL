  <!-- Footer / User Info -->
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="topbar-avatar" style="width:32px;height:32px;font-size:12px;">
          <%= typeof nama !== 'undefined' ? nama.charAt(0).toUpperCase() : (typeof user !== 'undefined' && user.nama ? user.nama.charAt(0).toUpperCase() : 'U') %>
        </div>
        <div>
          <div class="sidebar-user-name">
            <%= typeof nama !== 'undefined' ? nama : (typeof user !== 'undefined' && user.nama ? user.nama : 'Pengguna') %>
          </div>
          <div class="sidebar-user-role">
            <%= typeof user !== 'undefined' && user.kelas ? user.kelas + ' · Siswa' : 'Perpustakaan PESAT' %>
          </div>
        </div>
      </div>
    </div>
  </div>
