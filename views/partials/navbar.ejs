        <path d="M16 10C16 10 11 13 11 18C11 20.761 13.239 23 16 23C18.761 23 21 20.761 21 18C21 13 16 10 16 10Z" fill="#F97316"/>
      </svg>
    </div>
    <div>
      <div class="sidebar-name">SMA PESAT</div>
      <div class="sidebar-sub">School of Talent</div>
    </div>
