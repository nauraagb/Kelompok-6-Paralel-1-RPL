<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QR Tiket Peminjaman — Perpustakaan SMA PESAT</title>
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/navbar') %>

  <main class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-search">
        <span class="topbar-search-icon">
          <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </span>
        <input type="text" placeholder="Cari Koleksi...">
      </div>
      <div class="topbar-actions">
      </div>
    </div>

    <!-- Page Body -->
    <div class="page-body">
      <!-- Success Alert with Timer -->
      <div class="qr-alert">
        <div class="qr-alert-left">
          <div class="qr-alert-icon">
            <svg width="28" height="28" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <div class="qr-alert-title">Buku tersedia! Segera ambil ke perpustakaan</div>
            <div class="qr-alert-sub">Tunjukkan tiket QR Code kepada Admin di meja perpustakaan untuk validasi.</div>
          </div>
        </div>
        <div class="qr-timer">
          <svg width="20" height="20" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
          </svg>
          <span id="countdown">30:00</span>
        </div>
      </div>

      <!-- QR Content -->
      <h2 class="page-title">QR Code Tiket</h2>
      <div class="qr-content">
        <!-- QR Code -->
        <div class="qr-code-wrap">
          <img src="<%= qr %>" alt="QR Code Peminjaman">
        </div>

        <!-- Steps -->
        <div class="qr-steps">
          <div class="qr-step">
            <div class="qr-step-icon">
              <svg width="28" height="28" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2"/>
              </svg>
            </div>
            <div class="qr-step-num">Langkah 1</div>
            <div class="qr-step-title">Buka tiket ini</div>
            <div class="qr-step-desc">Simpan atau screenshot halaman tiket digital ini</div>
          </div>

          <div class="qr-step">
            <div class="qr-step-icon">
              <svg width="28" height="28" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
            </div>
            <div class="qr-step-num">Langkah 2</div>
            <div class="qr-step-title">Datang ke perpustakaan</div>
            <div class="qr-step-desc">Kunjungi perpustakaan</div>
          </div>

          <div class="qr-step">
            <div class="qr-step-icon">
              <svg width="28" height="28" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="qr-step-num">Langkah 3</div>
            <div class="qr-step-title">Temui admin</div>
            <div class="qr-step-desc">Cari meja admin dan tunjukkan kode QR kamu</div>
          </div>

          <div class="qr-step">
            <div class="qr-step-icon">
              <svg width="28" height="28" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="qr-step-num">Langkah 4</div>
            <div class="qr-step-title">Validasi</div>
            <div class="qr-step-desc">Admin scan QR dan menyerahkan bukunya ke kamu</div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/api/peminjam/katalog" class="btn btn-secondary">
          <svg width="14" height="14" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
          </svg>
          Kembali ke Katalog
        </a>
        <a href="/api/peminjam/riwayat" class="btn btn-primary">
          Lihat Riwayat
        </a>
      </div>
    </div>
  </main>
</div>
<script>
  document.querySelectorAll('.nav-item[data-page]').forEach(el => {
    if (el.dataset.page === 'katalog') el.classList.add('active');
  });

  // Countdown timer (30 minutes)
  let totalSeconds = 30 * 60;
  function updateTimer() {
    const m = Math.floor(totalSeconds / 60);
    const s = totalSeconds % 60;
    document.getElementById('countdown').textContent =
      String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    if (totalSeconds > 0) {
      totalSeconds--;
      setTimeout(updateTimer, 1000);
    } else {
      document.getElementById('countdown').textContent = 'Kedaluwarsa';
    }
  }
  updateTimer();
</script>
</body>
</html>
