<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Beranda | Perpustakaan SMA PESAT</title>
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/navbar') %>

  <main class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-search">
        <span class="topbar-search-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </span>
        <form action="/api/peminjam/searchBook" method="GET" style="display:contents;">
          <input type="text" name="q" placeholder="Cari koleksi...">
        </form>
      </div>
      <div class="topbar-actions">
        <div class="topbar-user-info">
          <div class="topbar-user-name"><%= nama %></div>
          <div class="topbar-user-role"><%= user.kelas ? user.kelas + ' · Siswa' : 'Perpustakaan PESAT' %></div>
        </div>
        <div class="topbar-avatar"><%= nama.charAt(0).toUpperCase() %></div>
      </div>
    </div>

    <!-- Page Body -->
    <div class="page-body">

      <!-- Welcome Banner -->
      <div class="welcome-banner">
        <div class="welcome-banner-body">
          <h2>Halo, <%= nama %>!</h2>
          <p>Mau baca apa hari ini?</p>
        </div>
      </div>

      <!-- Quick Action Cards -->
      <div class="action-grid">

        <a href="/api/peminjam/katalog" class="action-card">
          <div class="action-card-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
              <line x1="10" y1="7" x2="16" y2="7"/>
              <line x1="10" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
          <div class="action-card-label">Katalog Buku</div>
          <div class="action-card-desc">Cari dan lihat koleksi buku</div>
        </a>

        <a href="/api/peminjam/riwayat" class="action-card">
          <div class="action-card-icon green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9"/>
              <polyline points="12 7 12 12 15 15"/>
            </svg>
          </div>
          <div class="action-card-label">Riwayat Pinjaman</div>
          <div class="action-card-desc">Cek buku yang pernah kamu pinjam</div>
        </a>

        <a href="/api/peminjam/antrianSaya" class="action-card">
          <div class="action-card-icon amber">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <line x1="9" y1="6"  x2="20" y2="6"/>
              <line x1="9" y1="12" x2="20" y2="12"/>
              <line x1="9" y1="18" x2="20" y2="18"/>
              <circle cx="4" cy="6"  r="1" fill="currentColor" stroke="none"/>
              <circle cx="4" cy="12" r="1" fill="currentColor" stroke="none"/>
              <circle cx="4" cy="18" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <div class="action-card-label">Antrian Saya</div>
          <div class="action-card-desc">Lihat posisi antrianmu</div>
        </a>

        <a href="/api/peminjam/akun" class="action-card">
          <div class="action-card-icon purple">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
          </div>
          <div class="action-card-label">Akun Saya</div>
          <div class="action-card-desc">Info akun kamu</div>
        </a>

      </div>

      <!-- Library Info Card -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">Informasi Perpustakaan</span>
        </div>
        <div class="card-body">
          <div class="info-grid">

            <div class="info-item">
              <div class="info-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="9"/>
                  <polyline points="12 7 12 12 15 15"/>
                </svg>
              </div>
              <div>
                <div class="info-item-title">Jam Operasional</div>
                <div class="info-item-desc">Sen-Jum, 07.30-15.30</div>
              </div>
            </div>

            <div class="info-item">
              <div class="info-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                  <rect x="8" y="2" width="8" height="4" rx="1"/>
                  <line x1="9" y1="12" x2="15" y2="12"/>
                  <line x1="9" y1="16" x2="13" y2="16"/>
                </svg>
              </div>
              <div>
                <div class="info-item-title">Masa Pinjam</div>
                <div class="info-item-desc">Maks. 7 hari per buku</div>
              </div>
            </div>

            <div class="info-item">
              <div class="info-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <div class="info-item-title">Lokasi</div>
                <div class="info-item-desc">Gedung Utama, Lantai 1</div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </main>
</div>
<script>
  document.querySelectorAll('.nav-item[data-page]').forEach(el => {
    if (el.dataset.page === 'beranda') el.classList.add('active');
  });
</script>
</body>
</html>