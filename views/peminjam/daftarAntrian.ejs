<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Antrian Saya — Perpustakaan SMA PESAT</title>
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/navbar') %>

  <main class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-search">
        <span class="topbar-search-icon">
          <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </span>
        <form action="/api/peminjam/searchBook" method="GET" style="display:contents;">
          <input type="text" name="q" placeholder="Cari Koleksi...">
        </form>
      </div>
      <div class="topbar-actions">
      </div>
    </div>

    <!-- Page Body -->
    <div class="page-body">
      <h1 class="page-title">Antrian Saya</h1>

      <div class="card">
        <div class="card-header">
          <div>
            <span class="card-title">Daftar Antrian Buku</span>
            <div class="text-muted text-sm" style="margin-top:3px;">Buku yang sedang Anda tunggu karena stok habis.</div>
          </div>
          <span class="badge badge-gray"><%= antrian.length %> antrian</span>
        </div>

        <% if (antrian.length === 0) { %>
        <div class="card-body">
          <div class="empty-state">
            <div class="empty-state-icon">⏳</div>
            <h3>Tidak ada antrian aktif</h3>
            <p>Anda belum memiliki antrian buku saat ini.</p>
            <a href="/api/peminjam/katalog" class="btn btn-primary btn-sm" style="margin-top:12px;">Lihat Katalog</a>
          </div>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>No. Antrian</th>
                <th>Judul Buku</th>
                <th>Tanggal Daftar</th>
                <th>Status</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% antrian.forEach(function(item) { %>
              <tr>
                <td>
                  <span class="badge badge-blue">#<%= item.nomor_antrian %></span>
                </td>
                <td style="font-weight:600;"><%= item.judul || '—' %></td>
                <td class="text-muted">
                  <%= new Date(item.tgl_daftar).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                </td>
                <td>
                  <% if (item.status === 'menunggu') { %>
                    <span class="badge badge-orange">Menunggu Stok</span>
                  <% } else if (item.status === 'diproses') { %>
                    <span class="badge badge-blue">Buku Tersedia</span>
                  <% } else { %>
                    <span class="badge badge-gray"><%= item.status %></span>
                  <% } %>
                </td>
                <td>
                  <button class="btn btn-danger btn-sm" onclick="batalkanAntrian('<%= item.id %>')">Batalkan</button>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>
<script>
  document.querySelectorAll('.nav-item[data-page]').forEach(el => {
    if (el.dataset.page === 'antrian') el.classList.add('active');
  });

  async function batalkanAntrian(id) {
    if (!confirm('Yakin ingin membatalkan antrian ini?')) return;
    try {
      const res = await fetch(`/api/antrian/${id}`, { method: 'DELETE' });
      if (res.ok) { window.location.reload(); }
      else { alert('Gagal membatalkan antrian.'); }
    } catch (err) {
      alert('Terjadi kesalahan jaringan.');
    }
  }
</script>
</body>
</html>
