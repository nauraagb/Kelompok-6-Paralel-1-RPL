<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Riwayat | Perpustakaan SMA PESAT</title>
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/navbar') %>

  <main class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-search">
        <span class="topbar-search-icon">
          <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </span>
        <form action="/api/peminjam/searchBook" method="GET" style="display:contents;">
          <input type="text" name="q" placeholder="Cari koleksi...">
        </form>
      </div>
      <div class="topbar-actions">
      </div>
    </div>

    <!-- Page Body -->
    <div class="page-body">
      <h1 class="page-title">Riwayat Peminjaman</h1>

      <div class="card">
        <div class="card-header">
          <span class="card-title">Riwayat Pinjaman</span>
          <span class="badge badge-gray"><%= peminjaman.length %> transaksi</span>
        </div>
        <% if (peminjaman.length === 0) { %>
        <div class="card-body">
          <div class="empty-state">
            <div class="empty-state-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="width:48px;height:48px"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg></div>
            <h3>Belum ada riwayat</h3>
            <p>Pinjam buku dulu di katalog.</p>
            <a href="/api/peminjam/katalog" class="btn btn-primary btn-sm" style="margin-top:12px;">Lihat Katalog</a>
          </div>
        </div>
        <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Judul Buku</th>
                <th>Tgl Pengajuan</th>
                <th>Batas Kembali</th>
                <th>Tgl Kembali</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% peminjaman.forEach(function(row, index) { %>
              <tr>
                <td class="text-muted"><%= index + 1 %></td>
                <td style="font-weight:600;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  <%= row.judul %>
                </td>
                <td class="text-muted">
                  <%= row.tgl_pengajuan ? new Date(row.tgl_pengajuan).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-' %>
                </td>
                <td class="text-muted">
                  <%= row.tgl_kembali_rencana ? new Date(row.tgl_kembali_rencana).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-' %>
                </td>
                <td class="text-muted">
                  <%= row.tgl_kembali_aktual ? new Date(row.tgl_kembali_aktual).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-' %>
                </td>
                <td>
                  <% 
                    let badgeClass = 'status-menunggu';
                    if (row.status === 'dipinjam') badgeClass = 'status-dipinjam';
                    else if (row.status === 'dikembalikan') badgeClass = 'status-dikembalikan';
                    else if (row.status === 'terlambat') badgeClass = 'status-terlambat';
                    else if (row.status === 'batal') badgeClass = 'status-batal';
                    else if (row.status === 'ditolak') badgeClass = 'status-ditolak';
                    else if (row.status === 'selesai') badgeClass = 'status-selesai';
                  %>
                  <span class="status-badge <%= badgeClass %>"><%= row.status %></span>
                  <% if (row.status === 'ditolak' && row.catatan) { %>
                  <button class="btn-alasan" onclick="lihatAlasan(this)" data-alasan="<%= row.catatan %>">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Lihat alasan
                  </button>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>
<style>
  .btn-alasan {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 6px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    padding: 3px 8px;
    border-radius: 999px;
    letter-spacing: 0.01em;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .btn-alasan:hover { background: #fee2e2; border-color: #fca5a5; }
  #modal-alasan {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  #modal-alasan.open { display: flex; }
  #modal-alasan .modal-box {
    background: #fff;
    border-radius: 12px;
    padding: 28px 24px 20px;
    width: 90%;
    max-width: 420px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
  }
  #modal-alasan .modal-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #b91c1c;
  }
  #modal-alasan .modal-body {
    background: #fef2f2;
    border-radius: 8px;
    padding: 14px 16px;
    color: #7f1d1d;
    font-size: 14px;
    line-height: 1.6;
  }
  #modal-alasan .modal-footer {
    margin-top: 16px;
    display: flex;
    justify-content: flex-end;
  }
  #modal-alasan .btn-tutup {
    padding: 8px 20px;
    background: #f3f4f6;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }
  #modal-alasan .btn-tutup:hover { background: #e5e7eb; }
</style>

<div id="modal-alasan">
  <div class="modal-box">
    <div class="modal-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Alasan Penolakan
    </div>
    <div class="modal-body" id="modal-alasan-text"></div>
    <div class="modal-footer">
      <button class="btn-tutup" onclick="tutupAlasan()">Tutup</button>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.nav-item[data-page]').forEach(el => {
    if (el.dataset.page === 'riwayat') el.classList.add('active');
  });
  function lihatAlasan(btn) {
    document.getElementById('modal-alasan-text').textContent = btn.dataset.alasan;
    document.getElementById('modal-alasan').classList.add('open');
  }
  function tutupAlasan() {
    document.getElementById('modal-alasan').classList.remove('open');
  }
  document.getElementById('modal-alasan').addEventListener('click', function(e) {
    if (e.target === this) tutupAlasan();
  });
</script>
</body>
</html>