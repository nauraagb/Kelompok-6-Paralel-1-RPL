<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Katalog | Perpustakaan SMA PESAT</title>
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/navbar') %>

  <main class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-search">

  <form action="/api/peminjam/searchBook"
        method="GET"
        class="search-form">

    <!-- SEARCH -->
    <div class="search-input-wrapper">
      <span class="topbar-search-icon">
        <svg width="16" height="16"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor">

          <path stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0
                   7 7 0 0114 0z"/>
        </svg>
      </span>

      <input
        type="text"
        name="q"
        value="<%= typeof keyword !== 'undefined'
          ? keyword
          : '' %>"
        placeholder="Cari koleksi..."
      >
    </div>

    <!-- RIGHT FILTER -->
    <div class="search-right">

      <select name="kategori" class="genre-select">

        <option value="">Semua Genre</option>

        <option value="Novel"
          <%= kategori === 'Novel' ? 'selected' : '' %>>
          Novel
        </option>

        <option value="Teknologi"
          <%= kategori === 'Teknologi' ? 'selected' : '' %>>
          Teknologi
        </option>

        <option value="Sejarah"
          <%= kategori === 'Sejarah' ? 'selected' : '' %>>
          Sejarah
        </option>

        <option value="Sains"
          <%= kategori === 'Sains' ? 'selected' : '' %>>
          Sains
        </option>

        <option value="Pendidikan"
          <%= kategori === 'Pendidikan' ? 'selected' : '' %>>
          Pendidikan
        </option>

      </select>

      <button type="submit"
              class="btn btn-primary btn-sm">
        Filter
      </button>

    </div>

  </form>
</div>
      <div class="topbar-actions">
      </div>
    </div>

    <!-- Page Body -->
    <div class="page-body">
      <% const dataBuku = (typeof results !== 'undefined' && results.length > 0) ? results : (typeof buku !== 'undefined' ? buku : []); %>

      <!-- Header -->
      <div class="katalog-header">
        <h1>Katalog Buku</h1>
        <div class="katalog-toolbar">
          <% if (typeof keyword !== 'undefined' && keyword) { %>
          <span class="badge badge-orange">Hasil pencarian: "<%= keyword %>"</span>
          <a href="/api/peminjam/katalog" class="btn btn-secondary btn-sm">Reset</a>
          <% } %>
          <span class="text-muted text-sm"><%= dataBuku.length %> buku ditemukan</span>
        </div>
      </div>

      <!-- No results -->
      <% if (dataBuku.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="width:48px;height:48px"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg></div>
        <h3>Buku tidak ditemukan</h3>
        <% if (typeof keyword !== 'undefined' && keyword) { %>
        <p>Tidak ada hasil untuk "<%= keyword %>". Coba kata kunci lain.</p>
        <% } else { %>
        <p>Katalog masih kosong.</p>
        <% } %>
      </div>
      <% } else { %>

      <!-- Book Grid -->
      <div class="katalog-grid">
        <% dataBuku.forEach(function(b) { %>
        <div class="book-card">
          <div class="book-cover">
            <div class="book-cover-placeholder">
              <% if (b.cover) { %>
              <img src="<%= b.cover %>" class="book-cover-img">
              <% } %>
            </div>
          </div>
          <div class="book-info">
            <div class="book-title"><%= b.judul %></div>
            <div class="book-author"><%= b.pengarang %></div>
            <div class="book-category"><%= b.kategori %></div>
            <div class="book-stock">
              Stok Tersedia: <strong><%= b.stok_tersedia %></strong>
            </div>
          </div>
          <div class="book-actions">
            <a href="/api/peminjam/detail/<%= b.id %>" class="btn btn-primary btn-sm" style="width:100%;justify-content:center;">
              Detail
            </a>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </main>
</div>
<script>
  document.querySelectorAll('.nav-item[data-page]').forEach(el => {
    if (el.dataset.page === 'katalog') el.classList.add('active');
  });
</script>
</body>
</html>